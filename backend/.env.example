# ─────────────────────────────────────────────────────────────────────────────
#  AgentShield Backend — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# App
ENVIRONMENT=development
DEBUG=true

# Security  (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database  (SQLite for dev, Postgres in production)
DATABASE_URL=sqlite:///./agentshield.db
# DATABASE_URL=postgresql://user:password@localhost:5432/agentshield

# LLM Providers  (add keys for the providers you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# CORS  (comma-separated list of allowed origins)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
