# ─────────────────────────────────────────────────────────────────────────────
#  AgentShield Monorepo — Root .gitignore
#  Covers all three sub-projects: extension/, web-dashboard/, backend/
# ─────────────────────────────────────────────────────────────────────────────

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
dist-ssr/
extension/dist/
web-dashboard/dist/
.output/
.vinxi/
.nitro/

# ── TanStack / Vite caches ────────────────────────────────────────────────────
.tanstack/
**/.tanstack/

# ── Cloudflare / Wrangler ─────────────────────────────────────────────────────
.wrangler/
.dev.vars
*.local

# ── Python ────────────────────────────────────────────────────────────────────
backend/.venv/
backend/__pycache__/
backend/**/__pycache__/
backend/*.pyc
backend/*.pyo
backend/*.egg-info/
backend/agentshield.db

# ── Environment / Secrets ─────────────────────────────────────────────────────
.env
backend/.env
# .env.example is committed intentionally

# ── Platform tooling ──────────────────────────────────────────────────────────
.lovable/

# ── Editor / OS ───────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Temp / Migration ──────────────────────────────────────────────────────────
migrate.ps1
