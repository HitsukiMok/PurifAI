{
  "functions": {
    "api/**/*.py": {
      "runtime": "vercel-python@0.1.1"
    }
  },
  "rewrites": [
    {
      "source": "/api/feedback/stats",
      "destination": "/api/feedback_stats.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1.py"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
